# macOS
.DS_Store

# Dependencies
node_modules/

# SvelteKit
/build
/.svelte-kit
/src-tauri/.svelte-kit
/package

# Vite
vite.config.js.timestamp-*
vite.config.ts.timestamp-*

# Rust / Tauri
target/
dist/
# Built plugin bundles ARE tracked: the registry fixture checksum points at
# these exact bytes (see scripts/build-plugin.mjs).
!plugins/*/dist/

# Environment
.env
.env.*
!.env.example
.venv/

# Local databases and bd/Dolt runtime files
*.db
*.db-shm
*.db-wal
.dolt/

# App data
thumbnails/
outputs/

# Internal working docs (kept locally, never shipped in the public repo)
docs/internal/

# Tooling (Enzyme, Beads, Superpowers)
**/.enzyme/
**/.enzyme-embeddings/
.playwright-mcp/
.beads/
.superpowers/
.impeccable/live/sessions/
.worktrees/
.tdd-state.json
