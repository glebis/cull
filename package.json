{
  "name": "cull",
  "version": "0.2.1",
  "description": "Local-first desktop image viewer for AI-generated art workflows.",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "ci": "bash scripts/check-ci.sh",
    "ci:frontend": "bash scripts/check-ci.sh frontend",
    "ci:rust": "bash scripts/check-ci.sh rust",
    "preflight": "bash scripts/preflight.sh",
    "land:feature": "bash scripts/land-feature.sh",
    "hooks:install": "bash scripts/install-hooks.sh",
    "preflight:hook": "bash scripts/preflight.sh hook",
    "preflight:quick": "bash scripts/preflight.sh quick",
    "preflight:full": "bash scripts/preflight.sh full",
    "preflight:release": "bash scripts/preflight.sh release",
    "clean-machine-dmg-gate": "bash scripts/clean-machine-dmg-gate.sh",
    "clean-machine-dmg-gate:build-install": "bash scripts/clean-machine-dmg-gate.sh --build --install",
    "land": "bash scripts/land-session.sh",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "tauri": "tauri",
    "test": "vitest run",
    "test:e2e": "bash tests/e2e/run-e2e.sh",
    "test:perf": "vitest run src/lib/view-utils.test.ts -t \"grid rendering performance budget\"",
    "test:watch": "vitest",
    "audit:licenses": "node scripts/license-audit.mjs",
    "audit:supply-chain": "bash scripts/supply-chain-audit.sh",
    "audit:sbom": "bash scripts/supply-chain-audit.sh sbom",
    "bd": "bash scripts/bd.sh",
    "lint:issues": "node scripts/check-beads-acceptance.mjs"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/glebis/cull.git"
  },
  "bugs": {
    "url": "https://github.com/glebis/cull/issues"
  },
  "homepage": "https://github.com/glebis/cull#readme",
  "dependencies": {
    "@fontsource/eb-garamond": "^5.2.7",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "html-to-image": "^1.11.13",
    "umap-js": "^1.4.0",
    "virtua": "^0.49.1"
  },
  "devDependencies": {
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.65.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tauri-apps/cli": "^2",
    "svelte": "^5.56.3",
    "svelte-check": "^4.0.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "cookie": "0.7.2"
  }
}
