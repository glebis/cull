{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "window-*"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "opener:default",
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$HOME/**/*" },
        { "path": "$APPDATA/**/*" }
      ]
    },
    "dialog:default",
    "dialog:allow-confirm",
    "dialog:allow-ask",
    "deep-link:default"
  ]
}
