{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cull",
  "version": "0.2.1",
  "identifier": "com.glebkalinin.cull",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Cull",
        "width": 1200,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self' blob:",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "font-src": "'self' data:",
        "img-src": "'self' asset: http://asset.localhost blob: data:",
        "object-src": "'none'",
        "base-uri": "'none'",
        "frame-ancestors": "'none'",
        "style-src": "'self' 'unsafe-inline'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$APPDATA/thumbnails/**/*",
            "$APPDATA/generated/**/*"
          ]
        }
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["cull"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/glebis/cull/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU0QjYwMDM3QTFCNzlEM0MKUldROG5iZWhOd0MyVklwY0ZFSC9QZmJyVDd0aXN1T1JnaHdRbVBJYTduQVh0Q2I5Y2JDZWcyVDYK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "files": {
        "Resources/Cull.help": "help/Cull.help"
      },
      "dmg": {
        "background": "dmg/cull-dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 130,
          "y": 218
        },
        "applicationFolderPosition": {
          "x": 535,
          "y": 218
        }
      }
    },
    "fileAssociations": [
      {
        "ext": ["jpg", "jpeg"],
        "mimeType": "image/jpeg",
        "description": "JPEG Image"
      },
      {
        "ext": ["png"],
        "mimeType": "image/png",
        "description": "PNG Image"
      },
      {
        "ext": ["gif"],
        "mimeType": "image/gif",
        "description": "GIF Image"
      },
      {
        "ext": ["webp"],
        "mimeType": "image/webp",
        "description": "WebP Image"
      },
      {
        "ext": ["bmp"],
        "mimeType": "image/bmp",
        "description": "BMP Image"
      },
      {
        "ext": ["tiff", "tif"],
        "mimeType": "image/tiff",
        "description": "TIFF Image"
      },
      {
        "ext": ["heic", "heif"],
        "mimeType": "image/heic",
        "description": "HEIC Image"
      },
      {
        "ext": ["avif"],
        "mimeType": "image/avif",
        "description": "AVIF Image"
      },
      {
        "ext": ["jxl"],
        "mimeType": "image/jxl",
        "description": "JPEG XL Image"
      },
      {
        "ext": ["svg"],
        "mimeType": "image/svg+xml",
        "description": "SVG Image"
      },
      {
        "ext": ["ico"],
        "mimeType": "image/x-icon",
        "description": "Icon Image"
      },
      {
        "ext": ["cr2", "cr3"],
        "mimeType": "image/x-canon-cr2",
        "description": "Canon RAW Image"
      },
      {
        "ext": ["nef"],
        "mimeType": "image/x-nikon-nef",
        "description": "Nikon RAW Image"
      },
      {
        "ext": ["arw"],
        "mimeType": "image/x-sony-arw",
        "description": "Sony RAW Image"
      },
      {
        "ext": ["dng"],
        "mimeType": "image/x-adobe-dng",
        "description": "Adobe DNG Image"
      },
      {
        "ext": ["orf"],
        "mimeType": "image/x-olympus-orf",
        "description": "Olympus RAW Image"
      },
      {
        "ext": ["raf"],
        "mimeType": "image/x-fuji-raf",
        "description": "Fuji RAW Image"
      },
      {
        "ext": ["rw2"],
        "mimeType": "image/x-panasonic-rw2",
        "description": "Panasonic RAW Image"
      },
      {
        "ext": ["psd"],
        "mimeType": "image/vnd.adobe.photoshop",
        "description": "Photoshop Document"
      }
    ]
  }
}
